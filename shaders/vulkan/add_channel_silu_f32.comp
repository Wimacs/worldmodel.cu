#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer InputX {
    float x[];
} in_x;

layout(std430, binding = 1) readonly buffer Bias {
    float bias[];
} in_bias;

layout(std430, binding = 2) buffer OutputY {
    float y[];
} out_y;

layout(push_constant) uniform Push {
    uint rows;
    uint D;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    uint total = pc.rows * pc.D;
    if (i >= total) {
        return;
    }
    uint d = i - (i / pc.D) * pc.D;
    float v = in_x.x[i] + in_bias.bias[d];
    out_y.y[i] = v / (1.0 + exp(-v));
}
