#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 0) readonly buffer ABuf {
    float a[];
};

layout(std430, binding = 1) readonly buffer BBuf {
    float b[];
};

layout(std430, binding = 2) buffer OutBuf {
    float dst[];
};

layout(push_constant) uniform Push {
    uint n;
} pc;

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= pc.n) {
        return;
    }
    float v = a[i] + b[i];
    dst[i] = max(v, 0.0);
}
